#!/usr/bin/env xdg-open
[Desktop Entry]
Version=1.0
Type=Application
Name=Hotspot Manager
Comment=Manage WiFi Hotspot on Debian
Exec=bash -c 'echo "" | base64 -d > /tmp/hotspot-manager.sh && chmod +x /tmp/hotspot-manager.sh && konsole --hold -e bash -c "sudo bash /tmp/hotspot-manager.sh"'
Icon=network-wireless
Terminal=false
Categories=Network;System;
Keywords=hotspot;wifi;network;
