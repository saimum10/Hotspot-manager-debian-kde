#!/usr/bin/env xdg-open
[Desktop Entry]
Version=1.0
Type=Application
Name=Hotspot Manager
Comment=Manage WiFi Hotspot — Saimum | Debian
Exec=bash -c 'mkdir -p ~/.local/bin && echo "" | base64 -d > ~/.local/bin/hotspot-manager.sh && chmod 700 ~/.local/bin/hotspot-manager.sh && sudo bash ~/.local/bin/hotspot-manager.sh; rm -f ~/.local/bin/hotspot-manager.sh'
Icon=network-wireless
Terminal=true
Categories=Network;System;
Keywords=hotspot;wifi;network;
StartupNotify=false
