[Desktop Entry]
Categories=Network;System;
Comment=Manage WiFi Hotspot — Saimum | Debian
Exec=bash -c 'mkdir -p ~/.local/bin && echo "" | base64 -d > ~/.local/bin/hotspot-manager.py && chmod 700 ~/.local/bin/hotspot-manager.py && sudo python3 ~/.local/bin/hotspot-manager.py; rm -f ~/.local/bin/hotspot-manager.py'
Icon=network-wireless
Keywords=hotspot;wifi;network;
Name[en_US]=Hotspot ManagerGUI
Name=Hotspot ManagerGUI
StartupNotify=false
Terminal=true
Type=Application
Version=1.0
