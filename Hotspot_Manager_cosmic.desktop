#!/usr/bin/env xdg-open
[Desktop Entry]
Version=1.0
Type=Application
Name=Hotspot Manager
Comment=Manage WiFi Hotspot — cosmic-terminal
Exec=cosmic-terminal -- bash -c 'mkdir -p ~/.local/bin && echo "" | base64 -d > ~/.local/bin/hotspot-manager.py && chmod 700 ~/.local/bin/hotspot-manager.py && sudo python3 ~/.local/bin/hotspot-manager.py'
Icon=network-wireless
Terminal=false
Categories=Network;System;
Keywords=hotspot;wifi;network;
StartupNotify=false
